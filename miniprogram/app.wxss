page {
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: #1a56db;
  color: #fff;
  border-radius: 12rpx;
  margin: 24rpx;
}

.disclaimer {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
  padding: 0 24rpx 48rpx;
}

.tier-chong { color: #dc2626; }
.tier-wen { color: #2563eb; }
.tier-bao { color: #059669; }

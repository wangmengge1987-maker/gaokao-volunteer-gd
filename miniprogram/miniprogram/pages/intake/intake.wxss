.label {
  font-weight: 600;
  margin-bottom: 24rpx;
}

.check-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.check-item {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #fff;
}

.check-item.sel {
  border-color: #1a56db;
  background: #eff6ff;
  color: #1a56db;
}

.check-dot {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.check-dot-on {
  border-color: #1a56db;
  background: #1a56db;
  box-shadow: inset 0 0 0 4rpx #fff;
}

.hover {
  opacity: 0.7;
}

input {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 28rpx 20rpx;
  height: auto;
  min-height: 96rpx;
  box-sizing: border-box;
}

.row {
  display: flex;
  gap: 28rpx;
}

.col {
  flex: 1;
}
